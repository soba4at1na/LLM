# Database
DB_USER=llm_user
DB_PASSWORD=llm_secure_pass_123
DB_NAME=llm_db

# JWT
SECRET_KEY=your_super_secret_key_min_32_chars_change_in_prod
ACCESS_TOKEN_EXPIRE_MINUTES=30

# LLM Model
# MODEL_PATH=/app/models/qwen2.5-3b-instruct.Q4_K_M.gguf
MODEL_PATH=/app/models/qwen2.5-14b-instruct-uncensored-q5_k_m.gguf
# MODEL_PATH=/app/models/Qwen3.5-9B-Q4_K_M.gguf  # requires newer llama.cpp/llama-cpp-python with qwen35 support
MODEL_N_CTX=3072
MODEL_MAX_TOKENS=512
MODEL_N_THREADS=10
MODEL_N_THREADS_BATCH=10
MODEL_N_BATCH=256
MODEL_USE_MLOCK=false
MODEL_USE_MMAP=true
LLM_REQUEST_TIMEOUT_SECONDS=180

# Development
DISABLE_LLM=false
